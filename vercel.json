{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "pages/api/**": {
      "maxDuration": 60
    }
  },
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@supabase_key",
    "CLAUDE_API_KEY": "@claude_key",
    "RESEND_API_KEY": "@resend_key",
    "NEXT_PUBLIC_APP_URL": "@app_url"
  }
}
